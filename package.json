{
	"name": "wardalpsy.com",
	"private": true,
	"version": "0.0.4",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"gen": "wrangler types",
		"sveltia": "cp node_modules/@sveltia/cms/dist/sveltia-cms.js static/patrycja/sveltia-cms.js"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@iconify-json/tabler": "^1.2.33",
		"@iconify/svelte": "^5.2.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"sharp": "^0.34.5",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.84.0",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@sveltia/cms": "^0.156.1",
		"jspdf": "^4.2.1",
		"lenis": "^1.3.23",
		"resend": "^6.12.1",
		"signature_pad": "^5.1.3",
		"stripe": "^22.0.2"
	},
	"overrides": {
		"@vinejs/vine": "$zod"
	}
}
